{
  "name": "bun-hono-ssr",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "db:migrate": "bun scripts/migrate.ts",
    "db:types": "bun bun-sqlgen generate 'src/**/*.ts' --migrations src/db/migrations --out src/db/queries/queries.gen.d.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun --env-file=.env.test test --only-failures",
    "build": "bun run db:types && bun run typecheck && bun run test"
  },
  "dependencies": {
    "@ilbertt/bun-sqlgen": "^0.3.1",
    "eta": "^3.5.0",
    "hono": "^4.10.7"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3"
  }
}
