<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= it.title %></title>
    <link rel="icon" href="/assets/<%= it.assetVersion %>/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/assets/<%= it.assetVersion %>/app.css">
  </head>
  <body>
    <%~ include('../partials/header', it) %>
    <main class="container page">
      <%~ it.body %>
    </main>
    <%~ include('../partials/footer', it) %>
  </body>
</html>
